# Copy this file to .env and fill in your own credentials.

# OpenAI-compatible API endpoint used by LiteLLM and task agents.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# Optional alias used by some LiteLLM-based runners.
LITELLM_API_KEY=
LITELLM_API_BASE=https://api.openai.com/v1

# Required only for GAIA data download and web search.
HF_TOKEN=
SERPAPI_API_KEY=
SERPER_API_KEY=

# Required only for AppWorld runs.
APPWORLD_ROOT=appworld_root
APPWORLD_AGENT_IMAGE=appworld-agent-pypi:latest
APPWORLD_TASK_CACHE=data/appworld_task_cache.json
